# Copiá este archivo como `.env` en la carpeta `CRM Modular` (misma carpeta que package.json).
# No subas `.env` al repositorio.

# Personal Access Token de Airtable (scope: bases que uses)
AIRTABLE_TOKEN=pat_reemplazar_con_tu_token

# Alternativa si ya usás esta variable en otros proyectos:
# AIRTABLE_API_KEY=pat_...

# ID de la base CRM Modular (en la URL de Airtable: https://airtable.com/appXXXXXXXX/tbl...)
AIRTABLE_BASE_ID=appTckJW4L1GWrjoC

# Opcional: ID tabla Leads (17 caracteres, tal cual la URL de Airtable). Si está mal tipeado → 404 al guardar. Mejor borrarla y usar el default del código.
# VITE_AIRTABLE_LEADS_TABLE_API=tbl0cIs2by0wqny4U

# Opcional: tabla de notas (Notas_Leads o ID tble…). No uses solo "Notas" — no existe esa tabla.
# VITE_AIRTABLE_TABLE_NOTAS=Notas_Leads

# Solo el nombre del campo link (por defecto en código: lead; si en Airtable es leads, poné leads).
# VITE_AIRTABLE_NOTAS_LINK_FIELD=lead

# Opcional: record ID de Especialistas (recXXXXXXXXXXXXXX) para asignar vendedor / auditoría al guardar (tras ejecutar script 08).
# VITE_ESPECIALISTA_RECORD_ID=recXXXXXXXXXXXXXX
