# Copiá este archivo como `.env` en la carpeta `CRM Modular` (misma carpeta que package.json).
# No subas `.env` al repositorio.

# Personal Access Token de Airtable (scope: bases que uses)
AIRTABLE_TOKEN=pat_reemplazar_con_tu_token

# Alternativa si ya usás esta variable en otros proyectos:
# AIRTABLE_API_KEY=pat_...

# ID de la base CRM Modular (en la URL de Airtable: https://airtable.com/appXXXXXXXX/tbl...)
AIRTABLE_BASE_ID=appTckJW4L1GWrjoC

# Opcional: ID de la tabla Leads (tbl… en la URL de Airtable). El proxy usa la misma variable del lado servidor.
# AIRTABLE_TABLE_LEADS_ID=tbl0cIs2by0wqny4U
# VITE_AIRTABLE_TABLE_LEADS_ID=tbl0cIs2by0wqny4U

# Opcional: nombre exacto de la tabla de notas en Airtable (con guión bajo: Notas_Leads).
# No uses espacio ("Notas Leads"); si en Vercel quedó mal, borrá esta variable.
# VITE_AIRTABLE_TABLE_NOTAS=Notas_Leads

# Nombre exacto del campo en Notas_Leads que enlaza a Leads (lead = script 07; si lo creaste a mano como "leads", usá leads).
# VITE_AIRTABLE_NOTAS_LINK_FIELD=leads
